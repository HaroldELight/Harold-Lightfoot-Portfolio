import tkinter as tk
import genai

class ChatbotGUI:
    def __init__(self):
        self.window = tk.Tk()
        self.window.title("Chatbot")

        self.input_box = tk.Entry(self.window, width=50)
        self.input_box.pack()

        self.output_box = tk.Text(self.window, width=50, height=10)
        self.output_box.pack()

        self.send_button = tk.Button(self.window, text="Send", command=self.send_query)
        self.send_button.pack()

    def send_query(self):
        query = self.input_box.get()
        response = self.chatbot.query(query)
        self.output_box.insert(tk.END, response + "\n")

    def run(self):
        self.window.mainloop()

    def setup_chatbot(self):
        # Set up the chatbot with the local Ollama URL and the "qwen2.5:3b" model
        self.chatbot = genai.Chatbot(
            model="qwen2.5:3b",
            url="http://localhost:11434/v1/chat/completions"
        )

if __name__ == "__main__":
    chatbot_gui = ChatbotGUI()
    chatbot_gui.setup_chatbot()
    chatbot_gui.run()